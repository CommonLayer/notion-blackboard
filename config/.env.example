# Notion
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_OBJECTIVES_DB=
NOTION_TASK_QUEUE_DB=
NOTION_AGENT_REGISTRY_DB=
NOTION_RESULTS_DB=
NOTION_AUDIT_LOG_DB=
NOTION_FINAL_REPORTS_DB=
NOTION_VERSION=2025-09-03

# OpenRouter / OpenAI-compatible endpoint
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
OPENROUTER_TITLE=Notion Blackboard

# Models
MANAGER_MODEL=anthropic/claude-opus-4-5
WORKER_MODEL=openai/gpt-4o
REVIEWER_MODEL=google/gemini-2.5-flash-lite

# Runtime
REQUEST_TIMEOUT_SECONDS=45
BLACKBOARD_DRY_RUN=false
